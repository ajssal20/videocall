# Signaling Server URL
# Standardmäßig: localhost:3000 für Entwicklung
# Für Production: Ihre eigene Signaling-Server URL
VITE_SIGNALING_URL=http://localhost:3000

# TURN Server Konfiguration (optional, wird in peer.js gesetzt)
# Rufen Sie eine TURN-Server-Dokumentation auf (z.B. Twilio, XIRSYS)
# VITE_TURN_URL=turn:your-turn-server.com:3478
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-password
